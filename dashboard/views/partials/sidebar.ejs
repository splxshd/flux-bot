<%
  const p = locals.path || '';
  const gid = locals.activeGuildId || (locals.guild && locals.guild.id) || '';
  const isAdmin = !!gid;
  function nav(href) { return p === href || p.startsWith(href + '/') ? 'nav-item active' : 'nav-item'; }
%>
<nav class="sidebar">
  <!-- Logo -->
  <div class="sidebar-logo">
    <img src="/img/logo.png" alt="nights" onerror="this.style.display='none'" />
    <div>
      <div class="logo-name">nights</div>
      <div class="logo-tag">Dashboard</div>
    </div>
  </div>

  <% if (isAdmin && locals.guild) { %>
  <!-- Active guild -->
  <div class="sidebar-guild">
    <% if (locals.guild.icon) { %>
      <img src="https://cdn.discordapp.com/icons/<%= locals.guild.id %>/<%= locals.guild.icon %>.png?size=64" alt="" />
    <% } else { %>
      <div style="width:28px;height:28px;border-radius:6px;background:var(--surface2);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:var(--accent);flex-shrink:0;">
        <%= locals.guild.name ? locals.guild.name[0].toUpperCase() : '?' %>
      </div>
    <% } %>
    <span class="guild-name" title="<%= locals.guild.name %>"><%= locals.guild.name %></span>
    <a href="/dashboard/user" class="change-link">change</a>
  </div>
  <% } %>

  <!-- User navigation -->
  <% if (!isAdmin) { %>
  <div class="sidebar-section">
    <div class="sidebar-section-label">Menu</div>
    <a href="/dashboard/user" class="<%= nav('/dashboard/user') %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      My Servers
    </a>
  </div>
  <% } %>

  <!-- Admin navigation -->
  <% if (isAdmin) { %>
  <div class="sidebar-section">
    <div class="sidebar-section-label">Overview</div>
    <a href="/dashboard/admin/<%= gid %>" class="<%= p === '/dashboard/admin/' + gid ? 'nav-item active' : 'nav-item' %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      Overview
    </a>
  </div>
  <div class="sidebar-section">
    <div class="sidebar-section-label">Moderation</div>
    <a href="/dashboard/admin/<%= gid %>/moderation" class="<%= nav('/dashboard/admin/' + gid + '/moderation') %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      Cases & Warnings
    </a>
    <a href="/dashboard/admin/<%= gid %>/antiraid" class="<%= nav('/dashboard/admin/' + gid + '/antiraid') %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
      Anti-Raid
    </a>
  </div>
  <div class="sidebar-section">
    <div class="sidebar-section-label">Features</div>
    <a href="/dashboard/admin/<%= gid %>/giveaways" class="<%= nav('/dashboard/admin/' + gid + '/giveaways') %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z"/></svg>
      Giveaways
    </a>
    <a href="/dashboard/admin/<%= gid %>/tickets" class="<%= nav('/dashboard/admin/' + gid + '/tickets') %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 9a3 3 0 010 6v2a2 2 0 002 2h16a2 2 0 002-2v-2a3 3 0 010-6V7a2 2 0 00-2-2H4a2 2 0 00-2 2v2z"/></svg>
      Tickets
    </a>
    <a href="/dashboard/admin/<%= gid %>/autoresponder" class="<%= nav('/dashboard/admin/' + gid + '/autoresponder') %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
      Autoresponder
    </a>
  </div>
  <div class="sidebar-section">
    <div class="sidebar-section-label">Config</div>
    <a href="/dashboard/admin/<%= gid %>/settings" class="<%= nav('/dashboard/admin/' + gid + '/settings') %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
      Settings
    </a>
  </div>
  <% } %>

  <!-- Owner navigation -->
  <% if (locals.user && locals.user.id === locals.OWNER_ID) { %>
  <div class="sidebar-section">
    <div class="sidebar-section-label">Owner</div>
    <a href="/dashboard/owner" class="<%= nav('/dashboard/owner') %>">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      Owner Panel
    </a>
  </div>
  <% } %>

  <div class="sidebar-spacer"></div>

  <!-- User footer -->
  <% if (locals.user) { %>
  <div class="sidebar-user">
    <img src="<%= locals.user.avatar ? 'https://cdn.discordapp.com/avatars/' + locals.user.id + '/' + locals.user.avatar + '.png?size=64' : 'https://cdn.discordapp.com/embed/avatars/0.png' %>" alt="" />
    <div>
      <div class="u-name"><%= locals.user.username %></div>
      <div class="u-disc"><%= locals.user.discriminator && locals.user.discriminator !== '0' ? '#' + locals.user.discriminator : '' %></div>
    </div>
    <a href="/auth/logout" class="logout-btn">logout</a>
  </div>
  <% } %>
</nav>
